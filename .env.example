# =============================================================================
# Chain Gambler — Environment Variables Reference
# Copy this file to .env and fill in real values before starting the stack.
# NEVER commit .env to version control.
# =============================================================================

# === BROKER (MetaTrader 5) ===
MT5_LOGIN=                      # MetaTrader 5 account number (integer)
MT5_PASSWORD=                   # MetaTrader 5 account password
MT5_SERVER=                     # Broker server name (e.g. Exness-MT5Trial9)

# === SECURITY ===
AGI_CONTROL_TOKEN=              # API control token — min 32 random chars, guards POST /api/control
AGI_TOKEN=                      # Legacy token alias (start_server.sh); set same value as AGI_CONTROL_TOKEN
AGI_IS_LIVE=1                   # Set to 1 to enable live trading; 0 = dry-run / simulation

# === TELEGRAM ===
TELEGRAM_TOKEN=                 # Bot token from @BotFather (e.g. 123456:ABC-DEF...)
TELEGRAM_CHAT_ID=               # Your Telegram user ID or group chat ID

# === TRADING — Core ===
AGI_LIVE_ENABLED=true           # Master live-trading enable flag
AGI_REQUIRE_EXPLICIT_LIVE_ARM=false  # If true, requires an explicit /arm command before trading
AGI_TRADE_INTERVAL_SEC=60       # Seconds between trade decision cycles
AGI_TRAIL_INTERVAL_SEC=30       # Seconds between trailing-stop update cycles
AGI_EQUITY_POLL_SEC=15          # Seconds between equity/PnL polls
AGI_LOOP_SEC=5                  # Main engine loop sleep (seconds)

# === TRADING — Risk ===
AGI_RISK_PERCENT=1.0            # Risk per trade as % of account equity
AGI_MIN_LOTS=0.01               # Minimum lot size per order
AGI_MAX_POS_PER_SYMBOL=3        # Maximum concurrent open positions per symbol
AGI_SL_COOLDOWN_MIN=3           # Minutes of cooldown after a stop-loss hit
AGI_NEG_TIMEOUT_MIN=60          # Minutes to pause after net negative session
AGI_NEG_TIMEOUT_LOSS_PCT=       # Equity loss % that triggers the negative timeout
AGI_KELLY_FRACTION=1.0          # Full Kelly = 1.0; half Kelly = 0.5
AGI_COOLDOWN_SEC=45             # Minimum seconds between consecutive entries
AGI_MIN_HOLD_SEC=120            # Minimum seconds to hold a position before exit

# === TRADING — Signal Filters / Deadzones ===
AGI_DEADZONE_CONFIDENCE=0.99    # Confidence threshold below which no action is taken
AGI_ACTION_THRESHOLD=0.0001     # Minimum predicted action magnitude to trigger a trade
AGI_LOW_VOL_MIN_ACTION=0.0001   # Min action in low-volatility regime
AGI_MED_VOL_MIN_ACTION=0.0001   # Min action in medium-volatility regime
AGI_HIGH_VOL_MIN_ACTION=0.0001  # Min action in high-volatility regime
AGI_REVERSAL_THRESHOLD=         # Minimum reversal signal strength to act on
AGI_MIN_TREND_BARS=             # Minimum bars of trend confirmation required
AGI_MIN_QUALITY_SCORE=          # Minimum signal quality score gate

# Symbol-specific deadzone overrides (from start_server.sh)
AGI_DZ_EURUSD=0.18
AGI_DZ_GBPUSD=0.20
AGI_DZ_XAUUSD=0.22

# === TRADING — PPO / Ensemble Model ===
AGI_PPO_ENABLED=true            # Enable PPO model inference
AGI_PPO_BLEND=                  # Weight of PPO signal in ensemble blend (0.0–1.0)
AGI_PPO_WINDOW=                 # Lookback window for PPO feature construction
AGI_PPO_MIN_ABS=                # Minimum absolute PPO signal to act on
AGI_PPO_ENSEMBLE=false          # Enable multi-model voting ensemble
AGI_PPO_ENSEMBLE_THRESHOLD=     # Minimum agreement fraction for ensemble vote
AGI_PPO_ENSEMBLE_MIN_VOTES=     # Minimum number of model votes required

# === TRADING — Bias Correction ===
AGI_BIAS_WINDOW=50              # Rolling window for buy/sell bias calculation
AGI_BIAS_STRENGTH=0.3           # Correction multiplier applied to biased signals (0.0–1.0)
AGI_DIVERGENCE_LOOKBACK=        # Bars to look back for signal-price divergence

# === TRAINING / AUTONOMY ===
AGI_AUTONOMY_ENABLED=false      # Master autonomy loop enable (Server_AGI overrides to false internally)
AGI_AUTONOMY_AUTO_CANARY=true   # Automatically promote trained models to canary
AGI_AUTONOMY_TRAIN=false        # Enable background training during live operation
AGI_AUTONOMY_INTERVAL_SEC=3600  # Seconds between autonomy loop cycles
AGI_AUTONOMY_TRAIN_EVERY_SEC=   # Seconds between training runs (alternative to interval)
AGI_AUTONOMY_TRAIN_ON_START=false  # Trigger a training run at startup
AGI_TRAINING_CYCLE_SEC=         # Seconds between training cycles
AGI_TRAINING_CYCLE_EVERY_N=     # Run training every N main-loop ticks
AGI_TRAIN_INTERVAL_HOURS=2      # Hours between training runs (macro interval)
AGI_USE_SUBPROC_VECENV=0        # 1 = use subprocess-based parallel VecEnv for training

# === TRAINING — Gate Criteria (promotion guards) ===
AGI_GATE_REQUIRE_PAPERTRADE=    # Require paper-trade evaluation before promotion
AGI_GATE_REQUIRE_WALKFORWARD=   # Require walk-forward test before promotion
AGI_GATE_MIN_PAPER_TRADES=      # Minimum paper trades required
AGI_GATE_MIN_EVAL_RETURN=       # Minimum return in evaluation window
AGI_GATE_MIN_EVAL_SHARPE=       # Minimum Sharpe ratio in evaluation window
AGI_GATE_MAX_EVAL_DD=           # Maximum drawdown allowed in evaluation window
AGI_GATE_MIN_SCORE_DELTA=       # Minimum improvement over current champion

# === CANARY MODEL ===
CANARY_LOT_MULT=0.25            # Lot-size multiplier for canary (0.25 = quarter-size)
CANARY_MAX_LOSS_PCT=10          # Max allowed loss % before canary is retired
CANARY_MAX_DD=                  # Max drawdown % for canary retirement
CANARY_MAX_LOSS=                # Absolute dollar loss cap for canary
CANARY_MIN_TRADES=30            # Minimum trades before canary is evaluated

# === SIGNAL QUALITY — Low-Volatility Gate ===
AGI_LOW_VOL_MIN_TRADES=         # Min trade count required in low-vol regime assessment
AGI_LOW_VOL_MIN_EXPECTANCY=     # Min expectancy score in low-vol regime
AGI_LOW_VOL_MIN_PROFIT_FACTOR=  # Min profit factor in low-vol regime
AGI_LOW_VOL_MAX_RECENT_LOSS_STREAK=  # Max consecutive losses allowed in low-vol

# === BACKUP ===
AGI_BACKUP_DIR=./backups        # Directory for model/state backups
AGI_BACKUP_INTERVAL_HOURS=24    # Hours between automatic backups
AGI_MAX_BACKUPS=7               # Maximum number of backup snapshots to retain

# === SCHEDULING ===
AGI_HEARTBEAT_SEC=1800          # Seconds between Telegram heartbeat pings
AGI_DAILY_PROFIT_HOUR_UTC=      # UTC hour to send daily profit summary (0–23)
AGI_SYMBOL_CARD_SEC=15          # Seconds between per-symbol status card broadcasts
AGI_TRADE_LEARN_SEC=            # Seconds between trade learning updates
AGI_TRADE_LEARN_DAYS=           # Days of history used for trade learning
AGI_REVIEW_INTERVAL_SEC=120     # Seconds between open-position review checks
AGI_PNL_POLL=true               # Enable background PnL polling

# === NETWORK / INFRASTRUCTURE ===
AGI_HOST=0.0.0.0                # Bind address for the API server
AGI_PORT=9090                   # Port for the main API server (Server_AGI)
AGI_API_PORT=5000               # Port for the standalone api_server.py process
AGI_ALLOWED_ORIGINS=            # Comma-separated CORS origins (e.g. https://mydomain.com)
REDIS_URL=redis://redis:6379/0  # Redis connection URL used by the stack

# === BROKER PROFILE ===
AGI_BROKER_PROFILE=             # Named broker profile for spread/pip config overrides
AGI_NETWORK_PROFILE=            # Named network profile (e.g. vps, local)

# === EXTERNAL INTEGRATIONS ===
FINNHUB_API_KEY=                # Finnhub API key for economic calendar / news data
METAAPI_TOKEN=                  # MetaAPI.cloud token (alternative MT5 bridge)
METAAPI_ACCOUNT_ID=             # MetaAPI.cloud account ID

# === OLLAMA (local LLM — optional) ===
OLLAMA_URL=http://localhost:11434  # Base URL for Ollama inference server
OLLAMA_BASE_URL=http://localhost:11434  # Alias used by some modules
OLLAMA_MODEL=llama3              # Model name to use for Ollama inference

# === N8N AUTOMATION ===
N8N_PASSWORD=changeme           # Basic-auth password for the n8n UI (admin/N8N_PASSWORD)

# === PYTORCH ===
PYTHONUNBUFFERED=1
PYTORCH_ENABLE_MPS_FALLBACK=1   # Allow PyTorch MPS ops to fall back to CPU (Mac)
