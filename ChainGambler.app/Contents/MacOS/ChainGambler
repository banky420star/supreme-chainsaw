#!/bin/bash
# ═══════════════════════════════════════════════════════════════════════════════
# Chain Gambler macOS App Launcher
# Double-click the .app bundle to auto-launch the full trading stack + browser.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Make sure critical tools are in PATH ──
export PATH="/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/opt/homebrew/bin:$PATH"

# ── Paths ──
APP_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
PROJECT_DIR="$(dirname "$APP_DIR")"
LOG_DIR="$PROJECT_DIR/logs"
mkdir -p "$LOG_DIR"
export LOG_DIR

# ── Single-instance lock ──
LOCK_FILE="$PROJECT_DIR/.tmp/launcher.lock"
mkdir -p "$PROJECT_DIR/.tmp"
if [ -f "$LOCK_FILE" ]; then
    OLD_PID=$(cat "$LOCK_FILE" 2>/dev/null)
    if [ -n "$OLD_PID" ] && kill -0 "$OLD_PID" 2>/dev/null; then
        /usr/bin/osascript -e 'display alert "Chain Gambler already running" message "Another instance is active. If the window closed, wait 10s and try again."'
        exit 1
    fi
fi
echo $$ > "$LOCK_FILE"

# ── Clean up lock on exit ──
_cleanup() {
    rm -f "$LOCK_FILE"
}
trap _cleanup EXIT

# ── Find Python ──
PYTHON=""
for candidate in \
    "$PROJECT_DIR/.venv312/bin/python" \
    "$PROJECT_DIR/.venv/bin/python" \
    "/Library/Frameworks/Python.framework/Versions/3.13/bin/python3" \
    "/usr/local/bin/python3" \
    "/usr/bin/python3" \
    "$(which python3 2>/dev/null)" \
    "$(which python 2>/dev/null)"; do
    if [ -x "$candidate" ]; then
        PYTHON="$candidate"
        break
    fi
done

if [ -z "$PYTHON" ]; then
    /usr/bin/osascript -e 'display alert "Python not found" message "Install Python 3.12+ and create a venv."'
    exit 1
fi

# ── Full paths to system tools ──
LSOF="$(which lsof 2>/dev/null || echo /usr/sbin/lsof)"
CURL="$(which curl 2>/dev/null || echo /usr/bin/curl)"
PKILL="$(which pkill 2>/dev/null || echo /usr/bin/pkill)"
OPEN="$(which open 2>/dev/null || echo /usr/bin/open)"
OSASCRIPT="$(which osascript 2>/dev/null || echo /usr/bin/osascript)"

# ── Colors ──
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

# ── Log everything ──
exec >> "$LOG_DIR/launcher.log" 2>&1
echo "[$(date '+%Y-%m-%d %H:%M:%S')] Chain Gambler launcher starting..."
echo "[$(date '+%Y-%m-%d %H:%M:%S')] Python: $PYTHON"
echo "[$(date '+%Y-%m-%d %H:%M:%S')] Project: $PROJECT_DIR"

# ── Source .env if present (MT5 credentials, tokens, etc.) ──
if [ -f "$PROJECT_DIR/.env" ]; then
    set -a
    source "$PROJECT_DIR/.env"
    set +a
fi

# ── Environment (set early so Wine kill can use it) ──
export PYTHONPATH="$PROJECT_DIR"
export AGI_CONTROL_TOKEN=chain_gambler_2026
export AGI_API_PORT=5050
export CHAIN_GAMBLER_EXECUTION_MODE=demo
export CHAIN_GAMBLER_ACCOUNT_TYPE=demo
export WINE_PYTHON="/Users/bank/Library/Application Support/net.metaquotes.wine.metatrader5/drive_c/winpython/python.exe"
export WINE="/Volumes/AI_DRIVE/Applications/MetaTrader 5.app/Contents/SharedSupport/wine/bin/wine"
export WINESERVER="/Volumes/AI_DRIVE/Applications/MetaTrader 5.app/Contents/SharedSupport/wine/bin/wineserver"
export WINEPREFIX="/Users/bank/Library/Application Support/net.metaquotes.wine.metatrader5"

# ── Kill old processes ──
$PKILL -9 -f "Server_AGI" 2>/dev/null || true
$PKILL -9 -f "Python.api_server" 2>/dev/null || true
$PKILL -9 -f "api_server.py" 2>/dev/null || true
$PKILL -9 -f "proxy_frontend.py" 2>/dev/null || true
$PKILL -9 -f "start_mt5_wine_bridge.py" 2>/dev/null || true
$PKILL -9 -f "http.server 4180" 2>/dev/null || true
# Kill orphan Wine Python bridge processes (they survive pkill of parent)
$PKILL -9 -f "winpython/python.exe.*MT5Service" 2>/dev/null || true
$PKILL -9 -f "winpython/python.exe.*rpyc" 2>/dev/null || true
# Kill all Wine processes cleanly (wineserver -k shuts down the prefix properly)
if [ -x "$WINESERVER" ] && [ -n "$WINEPREFIX" ]; then
    WINEPREFIX="$WINEPREFIX" "$WINESERVER" -k 2>/dev/null || true
fi
$PKILL -9 -f "terminal64.exe" 2>/dev/null || true
$PKILL -9 -f "winedevice.exe" 2>/dev/null || true
$PKILL -9 wineserver 2>/dev/null || true
sleep 3

# ── Remove stale lock files ──
rm -f "$PROJECT_DIR/.tmp/server_agi.lock" "$PROJECT_DIR/.tmp/champion_cycle.lock" 2>/dev/null || true

# ── Additional Environment ──
export AGI_DEADZONE_CONFIDENCE=0.99
export AGI_ACTION_THRESHOLD=0.0001
export AGI_HIGH_VOL_MIN_ACTION=0.0001
export AGI_LOW_VOL_MIN_ACTION=0.0001
export AGI_MED_VOL_MIN_ACTION=0.0001
export AGI_MIN_LOTS=0.02
export AGI_RISK_PERCENT=1.0
export AGI_TRADE_INTERVAL_SEC=30
export AGI_NEG_TIMEOUT_MIN=60
export AGI_TRAIL_INTERVAL_SEC=15
export AGI_BIAS_WINDOW=50
export AGI_BIAS_STRENGTH=0.5
export AGI_EQUITY_POLL_SEC=15
export AGI_MAX_POS_PER_SYMBOL=3
export AGI_SL_COOLDOWN_MIN=3
export AGI_HEARTBEAT_SEC=1800
export CANARY_LOT_MULT=1.0
export CANARY_MAX_LOSS_PCT=10
export AGI_TRAIN_INTERVAL_HOURS=2

# ── Helper: test RPyC bridge with timeout ──
_test_bridge() {
    # Allow bridge TCP stack + MT5 terminal IPC to settle before probing
    sleep 8
    for _ in $(seq 1 6); do
        "$PYTHON" -c "
import rpyc, sys
try:
    c = rpyc.classic.connect('127.0.0.1', 18812)
    c._config['sync_request_timeout'] = 20
    c.execute('import MetaTrader5 as mt5')
    ok = c.eval('mt5.initialize()')
    if not ok:
        print('BRIDGE_TEST_ERROR: mt5.initialize() returned False', file=sys.stderr)
        sys.exit(1)
    sys.exit(0)
except Exception as e:
    print('BRIDGE_TEST_ERROR:', type(e).__name__, e, file=sys.stderr)
    sys.exit(1)
" >> "$LOG_DIR/bridge_test_errors.log" 2>&1 && return 0
        sleep 2
    done
    return 1
}

# ── Start MT5 Wine Bridge ──
echo -e "${YELLOW}[$(date '+%H:%M:%S')] Starting MT5 Wine Bridge...${NC}"
BRIDGE_PID=""
if [ -f "$PROJECT_DIR/scripts/start_mt5_wine_bridge.py" ]; then
    # Check if an existing bridge is healthy
    if _test_bridge; then
        echo -e "${GREEN}[$(date '+%H:%M:%S')] MT5 Wine Bridge already running.${NC}"
    else
        # Kill stale bridge + wineserver
        $PKILL -9 -f "start_mt5_wine_bridge.py" 2>/dev/null || true
        $PKILL -9 -f "winpython/python.exe.*MT5Service" 2>/dev/null || true
        $PKILL -9 -f "winpython/python.exe.*rpyc" 2>/dev/null || true
        if [ -x "$WINESERVER" ] && [ -n "$WINEPREFIX" ]; then
            WINEPREFIX="$WINEPREFIX" "$WINESERVER" -k 2>/dev/null || true
        fi
        $PKILL -9 -f "terminal64.exe" 2>/dev/null || true
        $PKILL -9 -f "winedevice.exe" 2>/dev/null || true
        $PKILL -9 wineserver 2>/dev/null || true
        sleep 3
        /usr/bin/python3 -u "$PROJECT_DIR/scripts/start_mt5_wine_bridge.py" > "$LOG_DIR/mt5_bridge.log" 2>&1 &
        BRIDGE_PID=$!
        # Wait for bridge RPyC to be ready (not just the port)
        for i in $(seq 1 90); do
            if _test_bridge; then
                echo -e "${GREEN}[$(date '+%H:%M:%S')] MT5 Wine Bridge online.${NC}"
                break
            fi
            echo -e "${YELLOW}[$(date '+%H:%M:%S')] Bridge test attempt $i failed, retrying...${NC}"
            sleep 1
        done
    fi
else
    echo "MT5 Wine Bridge script not found — skipping."
fi

# ── Start Backend ──
_start_backend() {
    "$PYTHON" -m Python.Server_AGI > "$LOG_DIR/server_agi.log" 2>&1 &
    BACKEND_PID=$!
    echo "$BACKEND_PID" > "$PROJECT_DIR/.tmp/launcher_backend.pid"
}

_start_api() {
    "$PYTHON" -m Python.api_server > "$LOG_DIR/api_server.log" 2>&1 &
    API_PID=$!
    echo "$API_PID" > "$PROJECT_DIR/.tmp/launcher_api.pid"
}

echo -e "${YELLOW}[$(date '+%H:%M:%S')] Starting Server_AGI...${NC}"
_start_backend

echo -e "${YELLOW}[$(date '+%H:%M:%S')] Starting API Server...${NC}"
_start_api

# ── Wait for API ──
echo -e "${YELLOW}[$(date '+%H:%M:%S')] Waiting for backend...${NC}"
for i in $(seq 1 60); do
    if $CURL -s http://localhost:5050/api/health >/dev/null 2>&1; then
        echo -e "${GREEN}[$(date '+%H:%M:%S')] Backend is online.${NC}"
        break
    fi
    sleep 1
done

# ── Start Frontend (static + API proxy) ──
echo -e "${YELLOW}[$(date '+%H:%M:%S')] Starting frontend proxy...${NC}"
if [ -d "$PROJECT_DIR/ui_lab_app/dist" ]; then
    "$PYTHON" "$PROJECT_DIR/scripts/proxy_frontend.py" 4180 5050 > "$LOG_DIR/frontend.log" 2>&1 &
    FRONTEND_PID=$!
    echo "$FRONTEND_PID" > "$PROJECT_DIR/.tmp/launcher_frontend.pid"
    sleep 2
    if $LSOF -i :4180 >/dev/null 2>&1; then
        echo -e "${GREEN}[$(date '+%H:%M:%S')] Frontend proxy online.${NC}"
    else
        echo -e "${RED}[$(date '+%H:%M:%S')] Frontend proxy failed to start!${NC}"
    fi
else
    echo -e "${RED}[$(date '+%H:%M:%S')] No dist folder found.${NC}"
fi

# ── Open Browser in App Mode ──
APP_URL="http://localhost:4180"

# Try Chrome app mode first (best native feel)
if [ -x "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome" ]; then
    $OPEN -na "Google Chrome" --args --app="$APP_URL" --window-size=1400,900
elif [ -x "/Applications/Brave Browser.app/Contents/MacOS/Brave Browser" ]; then
    $OPEN -na "Brave Browser" --args --app="$APP_URL" --window-size=1400,900
elif [ -x "/Applications/Microsoft Edge.app/Contents/MacOS/Microsoft Edge" ]; then
    $OPEN -na "Microsoft Edge" --args --app="$APP_URL" --window-size=1400,900
else
    # Fallback to default browser
    $OPEN "$APP_URL"
fi

# ── macOS Notification ──
$OSASCRIPT -e 'display notification "Chain Gambler is running in the browser" with title "Chain Gambler" sound name "Glass"'

# ── Keep process alive and auto-restart dead components ──
echo -e "${GREEN}[$(date '+%H:%M:%S')] Chain Gambler is running. Keep this window open.${NC}"
_bridge_failures=0
while true; do
    sleep 30
    # Check backend
    if [ -f "$PROJECT_DIR/.tmp/launcher_backend.pid" ]; then
        BPID=$(cat "$PROJECT_DIR/.tmp/launcher_backend.pid")
        if ! kill -0 "$BPID" 2>/dev/null; then
            echo -e "${YELLOW}[$(date '+%H:%M:%S')] Server_AGI died — restarting...${NC}"
            _start_backend
        fi
    fi
    # Check API
    if [ -f "$PROJECT_DIR/.tmp/launcher_api.pid" ]; then
        APID=$(cat "$PROJECT_DIR/.tmp/launcher_api.pid")
        if ! kill -0 "$APID" 2>/dev/null; then
            echo -e "${YELLOW}[$(date '+%H:%M:%S')] API server died — restarting...${NC}"
            _start_api
        fi
    fi
    # Check bridge (require 2 consecutive failures before restart)
    if ! _test_bridge; then
        _bridge_failures=$((_bridge_failures + 1))
        if [ "$_bridge_failures" -ge 2 ]; then
            echo -e "${YELLOW}[$(date '+%H:%M:%S')] Bridge lost (2 consecutive failures) — restarting...${NC}"
            $PKILL -9 -f "start_mt5_wine_bridge.py" 2>/dev/null || true
            $PKILL -9 -f "winpython/python.exe.*MT5Service" 2>/dev/null || true
            $PKILL -9 -f "winpython/python.exe.*rpyc" 2>/dev/null || true
            if [ -x "$WINESERVER" ] && [ -n "$WINEPREFIX" ]; then
                WINEPREFIX="$WINEPREFIX" "$WINESERVER" -k 2>/dev/null || true
            fi
            $PKILL -9 -f "terminal64.exe" 2>/dev/null || true
            $PKILL -9 -f "winedevice.exe" 2>/dev/null || true
            $PKILL -9 wineserver 2>/dev/null || true
            sleep 3
            /usr/bin/python3 -u "$PROJECT_DIR/scripts/start_mt5_wine_bridge.py" > "$LOG_DIR/mt5_bridge.log" 2>&1 &
            sleep 10
            _bridge_failures=0
        else
            echo -e "${YELLOW}[$(date '+%H:%M:%S')] Bridge test failed ($_bridge_failures/2), waiting...${NC}"
        fi
    else
        _bridge_failures=0
    fi
done
